# Supabase (무료 티어: https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (https://console.anthropic.com)
# 비용 절감: 기본값은 haiku 사용. 프리미엄은 sonnet으로 변경
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 이메일 알림 - Resend (무료 티어: 월 3,000건, https://resend.com)
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_EMAIL=owner@yourhospital.com

# Vercel Cron 보안 (임의 문자열 생성)
CRON_SECRET=your-random-secret-string

# Google Places API (선택 사항 - 구글 리뷰 수집용)
# 무료 크레딧 $200/월 제공
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# 앱 URL (Vercel 배포 후 설정)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
